# ClipConnect configuration

# Storage backend: "local" or "s3"
STORAGE_BACKEND=local

# Local storage directory (when STORAGE_BACKEND=local)
STORAGE_LOCAL_DIR=./media

# S3 settings (when STORAGE_BACKEND=s3)
# S3_ENDPOINT_URL=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Library/metadata directory
LIBRARY_DIR=./data

# Max upload size in bytes (default: 2 GiB)
MAX_UPLOAD_BYTES=2147483648

# Server bind address
HOST=127.0.0.1
PORT=8000
